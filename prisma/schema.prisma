generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  SYSTEM
  PROMOTION
  GAME_START
  GAME_RESULT
  PREDICTION_REMINDER
  SCORE_UPDATE
}

enum GameStatus {
  BEFORE
  LIVE
  RESULT
  CANCEL
}

enum PostGameReportStatus {
  PENDING
  GENERATING
  READY
  FAILED
}

enum PregamePreviewStatus {
  PENDING
  READY
  FAILED
}

model User {
  id                String             @id @default(cuid())
  email             String?            @unique
  name              String?
  favoriteTeam      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  lastNotifiedAt    DateTime?
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
}

model PushSubscription {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint       String    @unique
  p256dh         String
  auth           String
  expirationTime DateTime?
  enabled        Boolean   @default(true)
  userAgent      String?
  topics         Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastSeenAt     DateTime?

  @@index([userId])
  @@index([enabled, userId])
}

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType @default(SYSTEM)
  title       String
  body        String
  deeplinkUrl String?
  imageUrl    String?
  payload     Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isRead, createdAt(sort: Desc)])
}

model Game {
  id          String     @id @default(cuid())
  externalId  String     @unique
  homeTeam    String
  awayTeam    String
  homeScore   Int        @default(0)
  awayScore   Int        @default(0)
  status      GameStatus @default(BEFORE)
  isLineupNotified Boolean @default(false)
  gameDate    DateTime?
  startedAt   DateTime?
  endedAt     DateTime?
  lastScoreAlertKey String?
  lastScoreAlertAt  DateTime?
  lastSyncedAt DateTime  @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, updatedAt])
  @@index([homeTeam, awayTeam])
}

model PostGameReport {
  id         String               @id @default(cuid())
  externalId String
  teamId     String
  gameDate   DateTime?
  status     PostGameReportStatus @default(PENDING)
  title      String?
  bodyLines  Json?
  facts      Json?
  error      String?
  generatedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([externalId, teamId])
  @@index([teamId, gameDate])
  @@index([status, updatedAt])
}

model PregamePreview {
  id         String               @id @default(cuid())
  date       String
  teamId     String
  gameId     String
  opponentTeamId String
  gameTime   String
  stadium    String?
  status     PregamePreviewStatus @default(PENDING)
  title      String?
  bodyLines  Json?
  context    Json?
  error      String?
  generatedAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  @@unique([date, teamId])
  @@index([date, status])
  @@index([teamId, date])
}
